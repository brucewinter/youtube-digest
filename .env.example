# Google OAuth2 — YouTube Data API v3
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Anthropic — Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend — Email delivery
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=digest@yourdomain.com   # Must be a verified Resend sender domain
DIGEST_TO_EMAIL=brucewinter@gmail.com

# Optional: how many hours back to look for new videos (default: 24)
LOOKBACK_HOURS=24

# Optional: click tracking via Synology NAS
TRACKER_BASE_URL=http://192.168.86.180/youtube-tracker
TRACKER_SECRET=pick-a-random-secret-string
